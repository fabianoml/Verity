        <mxCell id="3QiwOCORIn0j5tFV69Tr-36" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;3.&amp;nbsp;Custo usando apenas Gemini 1.5 Pro&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Referência aproximada de preço:&lt;br&gt;&lt;ul&gt;&lt;li&gt;&lt;strong data-start=&quot;1063&quot; data-end=&quot;1073&quot;&gt;Input:&lt;/strong&gt; $3.50 / 1M tokens&lt;/li&gt;&lt;li&gt;&lt;strong data-start=&quot;1097&quot; data-end=&quot;1108&quot;&gt;Output:&lt;/strong&gt; $10.50 / 1M tokens&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;Custo por requisição&lt;br&gt;&lt;ul&gt;&lt;li&gt;Input:&amp;nbsp;10.000 tokens (0.01M tokens)&lt;/li&gt;&lt;/ul&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;0.01 × 3.50&amp;nbsp; = &lt;/span&gt;&lt;span data-start=&quot;1214&quot; data-end=&quot;1225&quot; style=&quot;background-color: transparent;&quot;&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;$0.035&lt;/b&gt;&lt;br&gt;&lt;p data-start=&quot;1227&quot; data-end=&quot;1234&quot; style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Output:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1.000 tokens (&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0.001M tokens)&lt;br&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; 0.001 × 10.50&amp;nbsp;= &lt;strong data-start=&quot;1279&quot; data-end=&quot;1291&quot;&gt;$0.0105&lt;br&gt;&lt;br&gt;&lt;/strong&gt;&lt;p&gt;&lt;/p&gt;&lt;p data-start=&quot;1293&quot; data-end=&quot;1314&quot; style=&quot;&quot;&gt;&lt;/p&gt;&lt;ul style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;li&gt;Total por requisição: $&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0.035 + $0.0105 ≈ &lt;/span&gt;&lt;strong data-start=&quot;1336&quot; data-end=&quot;1347&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;$0.045&lt;/strong&gt;&lt;/li&gt;&lt;/ul&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;strong data-start=&quot;1336&quot; data-end=&quot;1347&quot; style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;strong data-start=&quot;1336&quot; data-end=&quot;1347&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Custo Diário:&lt;/font&gt;&lt;/strong&gt;&lt;strong data-start=&quot;1336&quot; data-end=&quot;1347&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;10.000 &lt;/font&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;requisições&lt;/font&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;font style=&quot;&quot;&gt; &lt;/font&gt;× $0.045 =&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;strong data-start=&quot;1404&quot; data-end=&quot;1417&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;$450/dia&lt;/strong&gt;&lt;/font&gt;&lt;/strong&gt;&lt;p&gt;&lt;/p&gt;&lt;/span&gt;&lt;h3 data-start=&quot;1424&quot; data-end=&quot;1440&quot;&gt;&lt;strong data-start=&quot;1336&quot; data-end=&quot;1347&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 12px;&quot;&gt;&lt;strong data-start=&quot;1336&quot; data-end=&quot;1347&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Custo Mensal:&amp;nbsp;&lt;/font&gt;&lt;/strong&gt;&lt;/strong&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;$450 × 30 =&amp;nbsp;&lt;/span&gt;&lt;strong data-start=&quot;1456&quot; data-end=&quot;1474&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;$13.500 / mês&lt;/strong&gt;&lt;/font&gt;&lt;/h3&gt;&lt;/div&gt;" vertex="1">
