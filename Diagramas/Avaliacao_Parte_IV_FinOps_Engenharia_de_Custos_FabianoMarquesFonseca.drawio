        <mxCell id="3QiwOCORIn0j5tFV69Tr-85" parent="3QiwOCORIn0j5tFV69Tr-83" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;align=left;spacingLeft=6;overflow=hidden;html=1;whiteSpace=wrap;" value="&lt;u&gt;&lt;b&gt;817.50&lt;/b&gt;&lt;/u&gt;" vertex="1">
