        <mxCell id="3QiwOCORIn0j5tFV69Tr-51" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Custo do XGBoost&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;font-weight: bold;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;XGBoost rodando em &lt;/span&gt;&lt;span data-start=&quot;2025&quot; data-end=&quot;2050&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;Vertex AI / Cloud Run&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;.&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Custo estimado por inferência&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;≈ &lt;/span&gt;&lt;span data-start=&quot;2087&quot; data-end=&quot;2099&quot; style=&quot;font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;$0.0001&lt;/span&gt;&lt;br&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;strong data-start=&quot;2087&quot; data-end=&quot;2099&quot; style=&quot;font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;Para 300.000 inferências/mês:&amp;nbsp;&lt;/span&gt;&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;300k × 0.0001&lt;b&gt;&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;= &lt;/span&gt;&lt;strong data-start=&quot;2149&quot; data-end=&quot;2161&quot; style=&quot;font-weight: bold; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;$30/mês&lt;/strong&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="399.5" x="40.5" y="2200" as="geometry" />
        </mxCell>
        <mxCell id="3QiwOCORIn0j5tFV69Tr-53" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Custo Gemini Pro (casos complexos)&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Volume de requisições&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Total de pedidos: 10.000 pedidos/dia&lt;/li&gt;&lt;li&gt;Casos cinzentos: 30% = 10.000 × 0.30 = 3.000&lt;/li&gt;&lt;li&gt;Casos complexos dentro dos cinzentos: 10% = 3.000 × 0.10 = 300&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Requisições/dia para Gemini Pro: 300&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Requisições/mês (30 dias): 9000&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Input: 10.000 (0.01M) tokens&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Output: 1000 (0.001M) tokens&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Preço do Gemini 1.5 Pro (estimado)&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: $3.50 / 1M tokens&lt;/li&gt;&lt;li&gt;Output: $10.50 / 1M tokens&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo por requisição&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 0.01 × 3.50 = $0.035&lt;/li&gt;&lt;li&gt;Output: 0.001 × 10.50 = $0.0105&lt;/li&gt;&lt;li&gt;Custo total por requisição = 0.035 + 0.0105 = $0.0455&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Consumo de tokens diário&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input tokens: 300 × 10.000 = 3.000.000 tokens&lt;/li&gt;&lt;li&gt;Output tokens: 300 × 1.000 = 300.000 tokens&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo Diário&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 3M × 3.50/1M = 3 × 3.50 = $10.50&lt;/li&gt;&lt;li&gt;Output: 0.3M × 10.50/1M = 0.3 × 10.50 = $3.15&lt;/li&gt;&lt;li&gt;Custo diário total: 10.50 + 3.15 = $13.65&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Consumo de tokens mensal&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 3M × 30 = 90M tokens&lt;/li&gt;&lt;li&gt;Output: 0.3M × 30 = 9M tokens&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo Mensal&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 90M × 3.50/1M = 90 × 3.50 = $315.00&lt;/li&gt;&lt;li&gt;Output: 9M × 10.50/1M = 9 × 10.50 = $94.50&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo Mensal Total: 315 + 94.5 = $409.5&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="399.5" x="841" y="2500" as="geometry" />
        </mxCell>
        <mxCell id="3QiwOCORIn0j5tFV69Tr-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Custo Gemini Flash (casos cinzentos)&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Volume de requisições&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Total de pedidos: 10.000 pedidos/dia&lt;/li&gt;&lt;li&gt;Casos cinzentos: 30% = 10.000 × 0.30 = 3.000&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Requisições/dia para Gemini Flash: 3.000&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Requisições/mês (30 dias): 90.000&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Input: 10.000 (0.01M) tokens&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Output: 1000 (0.001M) tokens&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Preço do Gemini Flash&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: $0.35 / 1M tokens&lt;/li&gt;&lt;li&gt;Output: $0.70 / 1M tokens&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo por requisição&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 0.01 × 0.35 = $0.0035&lt;/li&gt;&lt;li&gt;Output: 0.001 × 0.70 = $0.0007&lt;/li&gt;&lt;li&gt;Custo total por requisição = 0.0035 + 0.0007 = $0.0042&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Consumo de tokens diário&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input tokens: 3.000 × 10.000 = 30.000.000 tokens&lt;/li&gt;&lt;li&gt;Output tokens: 3.000 × 1.000 = 3.000.000 tokens&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo Diário&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 30M × 0.35/1M = 30 × 0.35 = $10.50&lt;/li&gt;&lt;li&gt;Output: 3M × 0.70/1M = 3 × 0.70 = $2.10&lt;/li&gt;&lt;li&gt;Custo diário total: 10.50 + 2.10 = $13.65&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Consumo de tokens mensal&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 30M × 30 = 900M tokens&lt;/li&gt;&lt;li&gt;Output: 3M × 30 = 90M tokens&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo Mensal&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Input: 900M × 0.35/1M = 900 × 0.35 = $315.00&lt;/li&gt;&lt;li&gt;Output: 90M × 0.70/1M = 90 × 0.70 = $63.00&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Custo Mensal Total: 315.00 + 63.00 = $378.00&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="399.5" x="424.5" y="2490" as="geometry" />
        </mxCell>
