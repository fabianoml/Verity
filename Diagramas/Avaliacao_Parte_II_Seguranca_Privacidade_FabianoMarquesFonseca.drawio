        <mxCell id="7uIm9pzK7ymgNPtDu2-A-224" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="340" width="329" x="81" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="7uIm9pzK7ymgNPtDu2-A-118" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Segurança e Privacidade (Security by Design)  &lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="192.91" x="468.67999999999995" y="1186" as="geometry" />
        </mxCell>
        <mxCell id="7uIm9pzK7ymgNPtDu2-A-120" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b&gt;1 - Estratégia geral (Security by Design)&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;O modelo nunca deve ver PII desnecessária.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;Ingestão&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&amp;nbsp; &amp;nbsp;↓&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;Detecção de PII&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&amp;nbsp; &amp;nbsp;↓&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;Redação / Tokenização&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&amp;nbsp; &amp;nbsp;↓&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;Armazenamento seguro&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&amp;nbsp; &amp;nbsp;↓&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;GenAI recebe versão sanitizada&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;Separação clara entre:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Dados brutos sensíveis (zona restrita)&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Dados processados para LLM (zona controlada)&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="259" x="121" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="7uIm9pzK7ymgNPtDu2-A-132" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2 - Proteção de PII antes do GenAI&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Fazer uso do Cloud Data Loss Prevention para detectar:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;CPF&lt;/li&gt;&lt;li&gt;CNPJ&lt;/li&gt;&lt;li&gt;Nome&lt;/li&gt;&lt;li&gt;Endereço&lt;/li&gt;&lt;li&gt;Conta bancária&lt;/li&gt;&lt;li&gt;Email&lt;/li&gt;&lt;li&gt;Telefone&lt;/li&gt;&lt;li&gt;Dados customizados (regex)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;Email / Contrato&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ↓&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Cloud Data Loss Prevention&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ↓&lt;/div&gt;&lt;div style=&quot;&quot;&gt;PII identificada&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ↓&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Redação ou tokenização&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ↓&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Texto sanitizado → Embedding / LLM&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="316.41" x="673.59" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="7uIm9pzK7ymgNPtDu2-A-221" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b&gt;3 - Estratégia de ofuscação/redação&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;a) Redação (Masking): Substitui PII por marcador.Ideal para:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&amp;nbsp;Processamento por LLM&lt;/li&gt;&lt;li&gt;&amp;nbsp;RAG&lt;/li&gt;&lt;li&gt;&amp;nbsp;Logs&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;b) Tokenização Reversível: Substitui por token seguro.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Ideal quando:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&amp;nbsp;Precisa reidentificar depois&lt;/li&gt;&lt;li&gt;&amp;nbsp;Fluxo de crédito exige referência futura&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;c) Criptografia: não recomendada para LLM.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Texto criptografado não é interpretável pelo modelo.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Usado apenas para armazenamento.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="268" x="102" y="1850" as="geometry" />
        </mxCell>
        <mxCell id="7uIm9pzK7ymgNPtDu2-A-222" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;4- Controles de acesso (IAM + VPC Service Controls)&lt;br&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;a) IAM (Identity and Access Management): Mínimo acesso&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;Serviço Cloud Data Loss Prevention (DLP) somente leitura no bucket raw.&lt;/li&gt;&lt;li&gt;Serviço GenAI tem acesso apenas a dados sanitizados.&lt;/li&gt;&lt;li&gt;BigQuery vetorial somente com acesso restrito por dataset.&lt;/li&gt;&lt;li&gt;Humanos somente acesso via grupo controlado (workgroups).&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;b) VPC Service Controls: P&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;erímetro de segurança e proteção&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;evitando vazamento de dados para fora do projeto, acesso indevido externo, vazamento via API.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li&gt;BigQuery&lt;/li&gt;&lt;li&gt;Cloud Storage&lt;/li&gt;&lt;li&gt;Vertex AI&lt;/li&gt;&lt;li&gt;Serviço&amp;nbsp;&lt;/li&gt;&lt;li&gt;Cloud Data Loss Prevention&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Zona Restrita (PII)&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;- Cloud Storage RAW&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;- BigQuery RAW&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;- Cloud Data Loss Prevention&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;↓&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Sanitização&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;↓&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Zona Controlada&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;- Embeddings&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;- Banco Vetorial&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp;- Vertex LLM&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="430.5" x="661.59" y="1920" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
