        <mxCell id="7uIm9pzK7ymgNPtDu2-A-153" parent="1" style="editableCssRules=.*;html=1;shape=image;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" value="Cloud Monitoring" vertex="1">
