        <mxCell id="7uIm9pzK7ymgNPtDu2-A-161" edge="1" parent="1" style="endArrow=classic;html=1;rounded=0;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="1086.25" y="2160" />
            </Array>
