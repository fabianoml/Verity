        <mxCell id="7uIm9pzK7ymgNPtDu2-A-186" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Dados Não estruturados" vertex="1">
