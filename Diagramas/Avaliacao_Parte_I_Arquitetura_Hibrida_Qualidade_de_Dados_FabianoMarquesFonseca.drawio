        <mxCell id="7uIm9pzK7ymgNPtDu2-A-132" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Validação do Schema no Pub/Sub&lt;br&gt;&lt;br&gt;&lt;br&gt;Falha no Produtor da Mensagem:&lt;br&gt;&lt;li data-start=&quot;451&quot; data-end=&quot;470&quot;&gt;&lt;p data-start=&quot;453&quot; data-end=&quot;470&quot;&gt;A publicação da mensagem falha&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;471&quot; data-end=&quot;507&quot;&gt;&lt;p data-start=&quot;473&quot; data-end=&quot;507&quot;&gt;A mensagem &lt;span data-start=&quot;484&quot; data-end=&quot;507&quot;&gt;nem entra no tópico&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;471&quot; data-end=&quot;507&quot;&gt;&lt;p data-start=&quot;473&quot; data-end=&quot;507&quot;&gt;&lt;span data-start=&quot;484&quot; data-end=&quot;507&quot;&gt;Usa-se o Cloud Monitoring para alerta&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;471&quot; data-end=&quot;507&quot;&gt;&lt;p data-start=&quot;473&quot; data-end=&quot;507&quot;&gt;&lt;span data-start=&quot;484&quot; data-end=&quot;507&quot;&gt;Corrige problema no sistema Produtor&lt;br&gt;&lt;br&gt;Falha no Consumo da mensagem:&lt;br&gt;&lt;br&gt;O schema pode esta correto mas alguma validação de regra falha, por ex: valor &amp;gt; 0 e veio nulo (negativo).&lt;br&gt;&lt;br&gt;Neste caso o Dataflow encaminhará o dado para uma fila de tratamento (DLQ) (pub/sub).&lt;br&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="30" width="230" x="391.5" y="1730" as="geometry" />
        </mxCell>
