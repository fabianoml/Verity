        </mxCell>
        <mxCell id="3QiwOCORIn0j5tFV69Tr-134" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;i&gt;Você é um sistema de análise de crédito.&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Utilize apenas as evidências fornecidas.&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Se não houver evidência suficiente,&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;responda &quot;dados insuficientes&quot;.&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;&lt;br&gt;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Evidências:&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;&lt;br&gt;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Feature Store:&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;{info_01}: {valor_info_01}&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;{info_02}: {valor_info_02}&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;&lt;br&gt;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Documentos:&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;{texto recuperado do Banco Vetorial e convertido em texto}&lt;/i&gt;&lt;/div&gt;" vertex="1">
